#Использовать ".."
#Использовать asserts

// -----------------------------------------------------------------------------
// Тесты счётчика (Counter) и индикатора (Gauge).
// Проверяем: создание метрик, изменение значений, регистрацию в реестре,
// сбор метрик (Gather) и что в собранных семействах — ожидаемые значения.
// -----------------------------------------------------------------------------

// Счётчик: инкремент по одному, добавление произвольного числа, регистрация,
// сбор — в результате должно быть одно семейство с именем метрики и суммой 12.
// Сериализация в текст должна содержать эту метрику и значение.
&Тест
Процедура ТестДолжен_СчетчикИнкрементИДобавитьСборИСериализация() Экспорт
	Счетчик = PrometheusMetrics.НовыйСчетчик(
		Новый Структура("Имя, Справка", "requests_total", "Всего запросов"));
	PrometheusMetrics.ИнкрементСчетчика(Счетчик);
	PrometheusMetrics.ИнкрементСчетчика(Счетчик);
	PrometheusMetrics.ДобавитьКСчетчику(Счетчик, 10);

	PrometheusRegistry.ЗарегистрироватьОбязательно(Счетчик);
	Семейства = PrometheusRegistry.Собрать();

	Найдено = Ложь;
	Значение = 0;

	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "requests_total" Тогда
			Если Семейство.Сэмплы.Количество() > 0 Тогда
				Значение = Семейство.Сэмплы[0].Значение;
				Найдено = Истина;
			КонецЕсли;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьИстину(
		Найдено,
		"Должно быть семейство requests_total");
	Утверждения.ПроверитьРавенство(
		12, Значение,
		"Значение счётчика должно быть 12");

	Текст = PrometheusTextFormat.Сериализовать(Семейства);
	Утверждения.ПроверитьИстину(
		СтрНайти(Текст, "requests_total 12") > 0,
		"В тексте метрик должна быть строка requests_total 12");
КонецПроцедуры

// Индикатор: установка значения, инкремент/декремент на 1, добавление/вычитание числа.
// После сбора в семействе active_jobs должно быть значение 5+1-1+3-1 = 7.
&Тест
Процедура ТестДолжен_ИндикаторУстановкаИнкрементДекрементИСбор() Экспорт
	Индикатор = PrometheusMetrics.НовыйИндикатор(
		Новый Структура("Имя, Справка", "active_jobs", "Активные задания"));
	PrometheusMetrics.УстановитьИндикатор(Индикатор, 5);
	PrometheusMetrics.ИнкрементИндикатора(Индикатор);
	PrometheusMetrics.ДекрементИндикатора(Индикатор);
	PrometheusMetrics.ДобавитьКИндикатору(Индикатор, 3);
	PrometheusMetrics.ВычестьИзИндикатора(Индикатор, 1);

	PrometheusRegistry.ЗарегистрироватьОбязательно(Индикатор);
	Семейства = PrometheusRegistry.Собрать();

	Ожидаемое = 5 + 1 - 1 + 3 - 1;
	Найдено = Ложь;
	Значение = 0;

	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "active_jobs" И Семейство.Сэмплы.Количество() > 0 Тогда
			Значение = Семейство.Сэмплы[0].Значение;
			Найдено = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьИстину(Найдено, "Должно быть семейство active_jobs");
	Утверждения.ПроверитьРавенство(
		Ожидаемое, Значение,
		"Значение индикатора должно быть " + Ожидаемое);
КонецПроцедуры

#Использовать ".."
#Использовать asserts

// -----------------------------------------------------------------------------
// Тесты гистограммы (Histogram) и резюме (Summary).
// Гистограмма: бакеты с верхними границами, Observe; при сборе — _bucket, _sum, _count.
// Резюме: квантили, Observe; при сборе — сэмплы с quantile, _sum, _count.
// -----------------------------------------------------------------------------

// Гистограмма: задаём границы бакетов, вызываем Observe для нескольких значений.
// При сборе должны появиться сэмплы с суффиксами _bucket, _sum, _count; _count = 3.
&Тест
Процедура ТестДолжен_ГистограммаНаблюдениеИБакетыПриСборе() Экспорт
	Границы = Новый Массив;
	Границы.Добавить(0.1);
	Границы.Добавить(0.5);
	Границы.Добавить(1);
	Опции = Новый Структура(
		"Имя, Справка, ВерхниеГраницыБакетов",
		"request_duration_seconds", "Длительность запроса", Границы);
	Гистограмма = PrometheusMetrics.НоваяГистограмма(Опции);
	PrometheusMetrics.НаблюдатьГистограмму(Гистограмма, 0.05);
	PrometheusMetrics.НаблюдатьГистограмму(Гистограмма, 0.2);
	PrometheusMetrics.НаблюдатьГистограмму(Гистограмма, 0.7);

	PrometheusRegistry.ЗарегистрироватьОбязательно(Гистограмма);
	Семейства = PrometheusRegistry.Собрать();

	ЕстьBucket = Ложь;
	ЕстьSum = Ложь;
	ЕстьCount = Ложь;
	ЗначениеCount = 0;
	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "request_duration_seconds" Тогда
			Для Каждого Сэмпл Из Семейство.Сэмплы Цикл
				Если СтрЗаканчиваетсяНа(Сэмпл.ИмяСэмпла, "_bucket") Тогда
					ЕстьBucket = Истина;
				КонецЕсли;

				Если СтрЗаканчиваетсяНа(Сэмпл.ИмяСэмпла, "_sum") Тогда
					ЕстьSum = Истина;
				КонецЕсли;

				Если СтрЗаканчиваетсяНа(Сэмпл.ИмяСэмпла, "_count") Тогда
					ЕстьCount = Истина;
					ЗначениеCount = Сэмпл.Значение;
				КонецЕсли;
			КонецЦикла;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Утверждения.ПроверитьИстину(
		ЕстьBucket И ЕстьSum И ЕстьCount,
		"В гистограмме должны быть _bucket, _sum, _count");
	Утверждения.ПроверитьРавенство(3, ЗначениеCount, "_count должен быть 3");
КонецПроцедуры

// Резюме: задаём квантили 0.5 и 0.9, три наблюдения (100, 200, 300).
// При сборе: сэмплы с quantile, _count = 3, _sum = 600.
&Тест
Процедура ТестДолжен_РезюмеНаблюдениеИКвантилиПриСборе() Экспорт
	Квантили = Новый Массив;
	Квантили.Добавить(0.5);
	Квантили.Добавить(0.9);

	Опции = Новый Структура(
		"Имя, Справка, Квантили",
		"response_size_bytes", "Размер ответа", Квантили);
	Резюме = PrometheusMetrics.НовоеРезюме(Опции);

	PrometheusMetrics.НаблюдатьРезюме(Резюме, 100);
	PrometheusMetrics.НаблюдатьРезюме(Резюме, 200);
	PrometheusMetrics.НаблюдатьРезюме(Резюме, 300);

	PrometheusRegistry.ЗарегистрироватьОбязательно(Резюме);
	Семейства = PrometheusRegistry.Собрать();

	ЕстьCount = Ложь;
	ЕстьSum = Ложь;
	ЕстьQuantile = Ложь;
	ЗначениеCount = 0;
	ЗначениеSum = 0;

	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "response_size_bytes" Тогда
			Для Каждого Сэмпл Из Семейство.Сэмплы Цикл
				Если СтрЗаканчиваетсяНа(Сэмпл.ИмяСэмпла, "_count") Тогда
					ЕстьCount = Истина;
					ЗначениеCount = Сэмпл.Значение;
				КонецЕсли;

				Если СтрЗаканчиваетсяНа(Сэмпл.ИмяСэмпла, "_sum") Тогда
					ЕстьSum = Истина;
					ЗначениеSum = Сэмпл.Значение;
				КонецЕсли;

				Если Сэмпл.Свойство("Квантиль") Тогда
					ЕстьQuantile = Истина;
				КонецЕсли;
			КонецЦикла;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьИстину(
		ЕстьCount И ЕстьSum И ЕстьQuantile,
		"В summary должны быть _count, _sum и сэмплы с quantile");
	Утверждения.ПроверитьРавенство(3, ЗначениеCount, "_count должен быть 3");
	Утверждения.ПроверитьРавенство(600, ЗначениеSum, "_sum должен быть 600");
КонецПроцедуры

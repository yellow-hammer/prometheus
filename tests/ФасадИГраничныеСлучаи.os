#Использовать ".."
#Использовать asserts

// -----------------------------------------------------------------------------
// Тесты фасада Prometheus (создание метрик через фасад, реестр по умолчанию,
// СобратьМетрики с реестром и без, СериализоватьВТекст, ContentTypeМетрик)
// и граничные случаи: константные лейблы, экранирование в тексте формата.
// -----------------------------------------------------------------------------

// Фасад: создаём счётчик через Prometheus.НовыйСчетчик, собираем через
// Prometheus.СобратьМетрики() без аргумента (дефолтный реестр), сериализуем
// через Prometheus.СериализоватьВТекст; ContentTypeМетрик() возвращает строку для HTTP.
&Тест
Процедура ТестДолжен_ФасадСозданиеСборИСериализация() Экспорт
	Счетчик = Prometheus.НовыйСчетчик("facade_requests_total", "Запросы через фасад");
	PrometheusMetrics.ИнкрементСчетчика(Счетчик);

	Семейства = Prometheus.СобратьМетрики();
	Утверждения.ПроверитьИстину(
		Семейства.Количество() >= 1,
		"Должно быть хотя бы одно семейство");

	Текст = Prometheus.СериализоватьВТекст(Семейства);
	Утверждения.ПроверитьИстину(
		СтрНайти(Текст, "facade_requests_total") > 0,
		"В тексте должна быть метрика facade_requests_total");

	ТипКонтента = Prometheus.ContentTypeМетрик();
	Утверждения.ПроверитьИстину(
		СтрНайти(ТипКонтента, "text/plain") > 0,
		"Content-Type для HTTP должен содержать text/plain");
КонецПроцедуры

// Реестр по умолчанию возвращается; метрики, созданные через фасад, регистрируются
// в реестре и попадают в СобратьМетрики() без аргумента — проверяем, что семейство есть.
&Тест
Процедура ТестДолжен_РеестрПоУмолчаниюИСборБезАргумента() Экспорт
	Реестр = Prometheus.РеестрПоУмолчанию();
	Утверждения.ПроверитьИстину(Реестр <> Неопределено, "Реестр по умолчанию не должен быть Неопределено");

	Счетчик = Prometheus.НовыйСчетчик("default_registry_counter", "Счётчик в реестре по умолчанию");
	PrometheusMetrics.ИнкрементСчетчика(Счетчик);
	Семейства = Prometheus.СобратьМетрики();
	Найдено = Ложь;

	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "default_registry_counter" Тогда
			Найдено = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьИстину(
		Найдено,
		"В собранных метриках должно быть семейство default_registry_counter");
КонецПроцедуры

// Фасад НоваяГистограммаВектор и НовоеРезюмеВектор: создаём векторы через Prometheus,
// получаем экземпляр по лейблам, наблюдаем; при сборе должны появиться соответствующие сэмплы.
&Тест
Процедура ТестДолжен_ФасадГистограммаВекторИРезюмеВектор() Экспорт
	ИменаЛейблов = Новый Массив;
	ИменаЛейблов.Добавить("handler");
	Границы = Новый Массив;
	Границы.Добавить(0.1);
	Границы.Добавить(1);

	ВекторГистограммы = Prometheus.НоваяГистограммаВектор(
		"http_request_duration_seconds", "Длительность по хендлеру", ИменаЛейблов, Границы);
	ЗначенияЛейблов = Новый Массив;
	ЗначенияЛейблов.Добавить("index");
	ЭкземплярГистограммы = PrometheusVec.ГистограммаВекторСМетками(ВекторГистограммы, ЗначенияЛейблов);
	PrometheusMetrics.НаблюдатьГистограмму(ЭкземплярГистограммы, 0.05);

	Квантили = Новый Массив;
	Квантили.Добавить(0.5);
	ВекторРезюме = Prometheus.НовоеРезюмеВектор(
		"response_size_bytes", "Размер ответа по хендлеру", ИменаЛейблов, Квантили);
	ЭкземплярРезюме = PrometheusVec.РезюмеВекторСМетками(ВекторРезюме, ЗначенияЛейблов);
	PrometheusMetrics.НаблюдатьРезюме(ЭкземплярРезюме, 100);

	Семейства = Prometheus.СобратьМетрики();
	ЕстьГистограмма = Ложь;
	ЕстьРезюме = Ложь;

	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "http_request_duration_seconds" Тогда
			ЕстьГистограмма = Истина;
		КонецЕсли;

		Если Семейство.Имя = "response_size_bytes" Тогда
			ЕстьРезюме = Истина;
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьИстину(ЕстьГистограмма, "Должна быть гистограмма из фасада");
	Утверждения.ПроверитьИстину(ЕстьРезюме, "Должно быть резюме из фасада");
КонецПроцедуры

// Константные лейблы: при создании счётчика передаём КонстантныеЛейблы;
// при сборе в сэмпле должны быть эти лейблы.
&Тест
Процедура ТестДолжен_СчетчикСКонстантнымиЛейблами() Экспорт
	КонстантныеЛейблы = Новый Соответствие;
	КонстантныеЛейблы.Вставить("env", "test");
	КонстантныеЛейблы.Вставить("app", "prometheus-lib");
	Опции = Новый Структура(
		"Имя, Справка, КонстантныеЛейблы",
		"labeled_requests_total", "Запросы с лейблами", КонстантныеЛейблы);
	Счетчик = PrometheusMetrics.НовыйСчетчик(Опции);
	PrometheusMetrics.ИнкрементСчетчика(Счетчик);

	PrometheusRegistry.ЗарегистрироватьОбязательно(Счетчик);
	Семейства = PrometheusRegistry.Собрать();

	Найдено = Ложь;

	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "labeled_requests_total" И Семейство.Сэмплы.Количество() > 0 Тогда
			Лейблы = Семейство.Сэмплы[0].Лейблы;
			Найдено = Лейблы.Получить("env") = "test" И Лейблы.Получить("app") = "prometheus-lib";
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьИстину(
		Найдено,
		"В сэмпле должны быть константные лейблы env=test, app=prometheus-lib");
КонецПроцедуры

// Сериализация экранирует кавычки и обратный слэш в значениях лейблов —
// в выводе должны быть экранированные последовательности.
&Тест
Процедура ТестДолжен_СериализацияЭкранируетЗначенияЛейблов() Экспорт
	Лейблы = Новый Соответствие;
	Лейблы.Вставить("msg", "Say ""Hello""");
	Сэмпл = Новый Структура(
		"ИмяСэмпла, Лейблы, Значение",
		"escaped_total", Лейблы, 1);
	Семейство = Новый Структура(
		"Имя, Тип, Справка, Сэмплы",
		"escaped_total", "counter", "", Новый Массив);
	Семейство.Сэмплы.Добавить(Сэмпл);
	Семейства = Новый Массив;
	Семейства.Добавить(Семейство);

	Текст = PrometheusTextFormat.Сериализовать(Семейства);

	Утверждения.ПроверитьИстину(
		СтрНайти(Текст, "\""") > 0 Или СтрНайти(Текст, "Say ") > 0,
		"В тексте должно быть экранированное значение лейбла");
	Утверждения.ПроверитьИстину(
		СтрНайти(Текст, "escaped_total") > 0,
		"В тексте должна быть метрика escaped_total");
КонецПроцедуры

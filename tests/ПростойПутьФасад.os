#Использовать ".."
#Использовать asserts

// -----------------------------------------------------------------------------
// Тесты только через фасад Prometheus: один модуль для создания, операций
// (Инкремент, Добавить, Установить, Наблюдать) и получения по лейблам
// (СчетчикСЛейблами с массивом или Соответствием). Без PrometheusMetrics/PrometheusVec в коде.
// -----------------------------------------------------------------------------

// Счётчик и индикатор: создание через фасад, операции через Prometheus.Инкремент/Добавить/Установить.
&Тест
Процедура ТестДолжен_ФасадСчетчикИИндикаторТолькоPrometheus() Экспорт
	Счетчик = Prometheus.НовыйСчетчик("simple_requests_total", "Запросы");
	Prometheus.Инкремент(Счетчик);
	Prometheus.Добавить(Счетчик, 10);

	Индикатор = Prometheus.НовыйИндикатор("simple_active", "Активные");
	Prometheus.Установить(Индикатор, 5);
	Prometheus.Инкремент(Индикатор);
	Prometheus.Декремент(Индикатор);
	Prometheus.Вычесть(Индикатор, 1);

	Семейства = Prometheus.СобратьМетрики();
	ЗначениеСчетчика = Неопределено;
	ЗначениеИндикатора = Неопределено;

	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "simple_requests_total" И Семейство.Сэмплы.Количество() > 0 Тогда
			ЗначениеСчетчика = Семейство.Сэмплы[0].Значение;
		КонецЕсли;

		Если Семейство.Имя = "simple_active" И Семейство.Сэмплы.Количество() > 0 Тогда
			ЗначениеИндикатора = Семейство.Сэмплы[0].Значение;
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьРавенство(11, ЗначениеСчетчика, "Счётчик 1+10=11");
	Утверждения.ПроверитьРавенство(4, ЗначениеИндикатора, "Индикатор 5+1-1-1=4");
КонецПроцедуры

// Вектор счётчика: фасад НовыйСчетчикВектор, Prometheus.СчетчикСЛейблами с Соответствием, Prometheus.Инкремент/Добавить.
&Тест
Процедура ТестДолжен_ФасадВекторСчетчикаССоответствием() Экспорт
	ИменаЛейблов = Новый Массив;
	ИменаЛейблов.Добавить("method");
	ИменаЛейблов.Добавить("code");
	Вектор = Prometheus.НовыйСчетчикВектор("simple_http_total", "Запросы по методу и коду", ИменаЛейблов);

	ЛейблыGET = Новый Соответствие;
	ЛейблыGET.Вставить("method", "GET");
	ЛейблыGET.Вставить("code", "200");
	СчетчикGET = Prometheus.СчетчикСЛейблами(Вектор, ЛейблыGET);
	Prometheus.Инкремент(СчетчикGET);
	Prometheus.Инкремент(СчетчикGET);

	ЛейблыPOST = Новый Соответствие;
	ЛейблыPOST.Вставить("code", "201");
	ЛейблыPOST.Вставить("method", "POST");
	СчетчикPOST = Prometheus.СчетчикСЛейблами(Вектор, ЛейблыPOST);
	Prometheus.Добавить(СчетчикPOST, 3);

	Семейства = Prometheus.СобратьМетрики();
	СэмпловВсего = 0;
	ЗначениеGET = Неопределено;
	ЗначениеPOST = Неопределено;

	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "simple_http_total" Тогда
			СэмпловВсего = Семейство.Сэмплы.Количество();
			Для Каждого Сэмпл Из Семейство.Сэмплы Цикл
				Если Сэмпл.Лейблы.Получить("method") = "GET" Тогда
					ЗначениеGET = Сэмпл.Значение;
				ИначеЕсли Сэмпл.Лейблы.Получить("method") = "POST" Тогда
					ЗначениеPOST = Сэмпл.Значение;
				КонецЕсли;
			КонецЦикла;
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьРавенство(2, СэмпловВсего, "Две серии (GET и POST)");
	Утверждения.ПроверитьРавенство(2, ЗначениеGET, "GET: два инкремента");
	Утверждения.ПроверитьРавенство(3, ЗначениеPOST, "POST: Add(3)");
КонецПроцедуры

// Гистограмма и резюме: создание через фасад, наблюдение через Prometheus.Наблюдать.
&Тест
Процедура ТестДолжен_ФасадГистограммаИРезюмеНаблюдать() Экспорт
	Границы = Новый Массив;
	Границы.Добавить(0.5);
	Границы.Добавить(1);
	Гистограмма = Prometheus.НоваяГистограмма("simple_duration_seconds", "Длительность", Границы);
	Prometheus.Наблюдать(Гистограмма, 0.2);
	Prometheus.Наблюдать(Гистограмма, 0.7);

	Квантили = Новый Массив;
	Квантили.Добавить(0.5);
	Резюме = Prometheus.НовоеРезюме("simple_size_bytes", "Размер", Квантили);
	Prometheus.Наблюдать(Резюме, 100);
	Prometheus.Наблюдать(Резюме, 200);

	Семейства = Prometheus.СобратьМетрики();
	ЕстьГистограмма = Ложь;
	ЕстьРезюме = Ложь;

	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "simple_duration_seconds" Тогда
			ЕстьГистограмма = Истина;
		КонецЕсли;
		Если Семейство.Имя = "simple_size_bytes" Тогда
			ЕстьРезюме = Истина;
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьИстину(ЕстьГистограмма, "Должна быть гистограмма");
	Утверждения.ПроверитьИстину(ЕстьРезюме, "Должно быть резюме");
КонецПроцедуры

// Вектор с массивом значений лейблов (как раньше): СчетчикСЛейблами(Вектор, Массив).
&Тест
Процедура ТестДолжен_ФасадВекторСМассивомЛейблов() Экспорт
	ИменаЛейблов = Новый Массив;
	ИменаЛейблов.Добавить("x");
	Вектор = Prometheus.НовыйСчетчикВектор("simple_vec_total", "Вектор", ИменаЛейблов);

	ЗначенияЛейблов = Новый Массив;
	ЗначенияЛейблов.Добавить("a");
	Счетчик = Prometheus.СчетчикСЛейблами(Вектор, ЗначенияЛейблов);
	Prometheus.Инкремент(Счетчик);

	Семейства = Prometheus.СобратьМетрики();
	Найдено = Ложь;
	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "simple_vec_total" И Семейство.Сэмплы.Количество() = 1 Тогда
			Найдено = Семейство.Сэмплы[0].Лейблы.Получить("x") = "a";
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьИстину(Найдено, "Одна серия с x=a");
КонецПроцедуры

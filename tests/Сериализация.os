#Использовать ".."
#Использовать asserts

// -----------------------------------------------------------------------------
// Тесты сериализации в Prometheus text format: массив семейств → строка с
// # HELP, # TYPE, строками метрик; Content-Type для HTTP-ответа.
// -----------------------------------------------------------------------------

// Вручную формируем одно семейство с одним сэмплом (counter с лейблами).
// Сериализатор должен выдать # HELP, # TYPE, строку с метрикой и значением 42.
// Content-Type должен содержать text/plain и version 0.0.4.
&Тест
Процедура ТестДолжен_СериализацияСемействаВТекстИContentType() Экспорт
	Лейблы = Новый Соответствие;
	Лейблы.Вставить("method", "get");
	Лейблы.Вставить("code", "200");

	Сэмпл = Новый Структура(
		"ИмяСэмпла, Лейблы, Значение",
		"http_requests_total", Лейблы, 42);
	Семейство = Новый Структура(
		"Имя, Тип, Справка, Сэмплы",
		"http_requests_total", "counter", "Всего запросов", Новый Массив);
	Семейство.Сэмплы.Добавить(Сэмпл);

	Семейства = Новый Массив;
	Семейства.Добавить(Семейство);

	Текст = PrometheusTextFormat.Сериализовать(Семейства);

	Утверждения.ПроверитьИстину(
		СтрНайти(Текст, "# HELP http_requests_total") > 0,
		"Ожидалась строка # HELP http_requests_total");
	Утверждения.ПроверитьИстину(
		СтрНайти(Текст, "# TYPE http_requests_total counter") > 0,
		"Ожидалась строка # TYPE http_requests_total counter");
	Утверждения.ПроверитьИстину(
		СтрНайти(Текст, "http_requests_total{") > 0,
		"Ожидалась строка с метрикой и лейблами");
	Утверждения.ПроверитьИстину(СтрНайти(Текст, "42") > 0, "Ожидалось значение 42 в тексте");

	ТипКонтента = PrometheusTextFormat.ContentType();

	Утверждения.ПроверитьИстину(
		СтрНайти(ТипКонтента, "text/plain") > 0 И СтрНайти(ТипКонтента, "0.0.4") > 0,
		"Content-Type должен содержать text/plain и version 0.0.4");
КонецПроцедуры

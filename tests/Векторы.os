#Использовать ".."
#Использовать asserts

// -----------------------------------------------------------------------------
// Тесты векторных метрик (CounterVec, GaugeVec): получение экземпляра по лейблам,
// изменение значений, удаление одной серии (Remove), очистка всех (Clear).
// При сборе после Remove остаётся только одна серия; после Clear — ноль сэмплов.
// -----------------------------------------------------------------------------

// CounterVec: два набора лейблов (GET/200 и POST/201), инкремент и Add.
// Удаляем серию POST/201; при сборе у http_requests_total должен остаться один сэмпл.
// GaugeVec: одна серия (queue=default), Set; затем Clear — при сборе у queue_size 0 сэмплов.
&Тест
Процедура ТестДолжен_ВекторыЛейблыУдалениеСерииИОчистка() Экспорт
	ИменаЛейблов = Новый Массив;
	ИменаЛейблов.Добавить("method");
	ИменаЛейблов.Добавить("code");
	ОпцииСчетчик = Новый Структура(
		"Имя, Справка, ИменаПеременныхЛейблов",
		"http_requests_total", "Запросы по методу и коду", ИменаЛейблов);
	ВекторСчетчик = PrometheusVec.НовыйСчетчикВектор(ОпцииСчетчик);

	ЗначенияМетокGET = Новый Массив;
	ЗначенияМетокGET.Добавить("GET");
	ЗначенияМетокGET.Добавить("200");
	СчетчикGET = PrometheusVec.СчетчикВекторСМетками(ВекторСчетчик, ЗначенияМетокGET);
	PrometheusMetrics.ИнкрементСчетчика(СчетчикGET);

	ЗначенияМетокPOST = Новый Массив;
	ЗначенияМетокPOST.Добавить("POST");
	ЗначенияМетокPOST.Добавить("201");
	СчетчикPOST = PrometheusVec.СчетчикВекторСМетками(ВекторСчетчик, ЗначенияМетокPOST);
	PrometheusMetrics.ДобавитьКСчетчику(СчетчикPOST, 2);
	PrometheusVec.ВекторУдалить(ВекторСчетчик, ЗначенияМетокPOST);
	PrometheusRegistry.ЗарегистрироватьОбязательно(ВекторСчетчик);

	ИменаОчереди = Новый Массив;
	ИменаОчереди.Добавить("queue");
	ОпцииИндикатор = Новый Структура(
		"Имя, Справка, ИменаПеременныхЛейблов",
		"queue_size", "Размер очереди", ИменаОчереди);
	ВекторИндикатор = PrometheusVec.НовыйИндикаторВектор(ОпцииИндикатор);

	ЗначенияДефолт = Новый Массив;
	ЗначенияДефолт.Добавить("default");
	ИндикаторДефолт = PrometheusVec.ИндикаторВекторСМетками(ВекторИндикатор, ЗначенияДефолт);
	PrometheusMetrics.УстановитьИндикатор(ИндикаторДефолт, 10);
	PrometheusVec.ВекторОчистить(ВекторИндикатор);
	PrometheusRegistry.ЗарегистрироватьОбязательно(ВекторИндикатор);

	Семейства = PrometheusRegistry.Собрать();

	СчетчикСэмплов = 0;
	ЗначениеСчетчика = Неопределено;
	Для Каждого Семейство Из Семейства Цикл
		Если Семейство.Имя = "http_requests_total" Тогда
			СчетчикСэмплов = Семейство.Сэмплы.Количество();
			Если Семейство.Сэмплы.Количество() > 0 И Семейство.Сэмплы[0].Свойство("Значение") Тогда
				ЗначениеСчетчика = Семейство.Сэмплы[0].Значение;
			КонецЕсли;
		КонецЕсли;

		Если Семейство.Имя = "queue_size" Тогда
			Утверждения.ПроверитьРавенство(
				0, Семейство.Сэмплы.Количество(),
				"После Clear у queue_size должно быть 0 сэмплов");
		КонецЕсли;
	КонецЦикла;

	Утверждения.ПроверитьИстину(
		СчетчикСэмплов = 1,
		"После Remove у http_requests_total должен быть один сэмпл (GET/200)");
КонецПроцедуры
